# Terraform state — never commit
*.tfstate
*.tfstate.backup
*.tfplan

# Terraform working directories
.terraform/

# Local backend config — contains storage account details
*backend.hcl

# Variable files that may contain sensitive values
*.auto.tfvars
!*.auto.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Claude Code local settings (personal overrides, not shared)
.claude/settings.local.json